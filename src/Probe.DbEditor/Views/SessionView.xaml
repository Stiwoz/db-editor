<UserControl x:Class="Probe.DbEditor.Views.SessionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
    xmlns:completion="clr-namespace:ICSharpCode.AvalonEdit.CodeCompletion;assembly=ICSharpCode.AvalonEdit"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    d:DesignHeight="720"
    d:DesignWidth="1080"
    Loaded="SessionView_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="160" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
            Background="{StaticResource SurfaceBrush}"
            Padding="8">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock x:Name="SessionTitleText"
                        DockPanel.Dock="Left"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Margin="0,0,0,0" />
                    <Separator Style="{StaticResource SeparatorStyle}"
                        Margin="12,0,12,0" Width="1" />
                    <TextBlock VerticalAlignment="Center" Margin="0,0,6,0" Text="Limit:" />
                    <TextBox x:Name="LimitTextBox" Width="32" Text="500" Margin="0,0,0,0" />
                    <Separator Style="{StaticResource SeparatorStyle}"
                        Margin="12,0,12,0" Width="1" />
                    <CheckBox x:Name="DeferEditsToggle"
                        Content="Review edits before apply"
                        IsChecked="True"
                        VerticalAlignment="Center"
                        Margin="0,0,0,0" />
                    <Separator Style="{StaticResource SeparatorStyle}"
                        Margin="12,0,12,0" Width="1" />
                    <Button Content="Refresh" Padding="10,4" Margin="0,0,8,0" Click="Refresh_Click" />
                    <Button x:Name="ApplyEditsButton" Content="Apply Edits" Padding="10,4"
                        Margin="0,0,8,0"
                        Click="ApplyPending_Click" />
                    <Button x:Name="RevertEditsButton" Content="Revert Edits" Padding="10,4"
                        Click="RevertPending_Click" />
                </StackPanel>
                <StackPanel x:Name="GlobalRunningIndicator"
                    DockPanel.Dock="Right"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="14,0,0,0"
                    Visibility="Collapsed">
                    <Grid Width="16" Height="16" Margin="0,0,6,0">
                        <Ellipse Width="14"
                            Height="14"
                            Stroke="{StaticResource BorderBrush}"
                            StrokeThickness="2"
                            Opacity="0.35" />
                        <Path Width="14"
                            Height="14"
                            Stroke="{StaticResource AccentBrush}"
                            StrokeThickness="2"
                            StrokeStartLineCap="Round"
                            StrokeEndLineCap="Round"
                            Data="M 7,0 A 7,7 0 0 1 14,7"
                            RenderTransformOrigin="0.5,0.5">
                            <Path.RenderTransform>
                                <RotateTransform />
                            </Path.RenderTransform>
                            <Path.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                From="0"
                                                To="360"
                                                Duration="0:0:0.9" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Path.Triggers>
                        </Path>
                    </Grid>
                    <TextBlock VerticalAlignment="Center" Text="Running..." />
                </StackPanel>
                <TextBlock x:Name="GlobalResultSummaryText"
                    DockPanel.Dock="Right"
                    VerticalAlignment="Center"
                    Margin="14,0,0,0"
                    Foreground="{StaticResource MutedTextBrush}"
                    Visibility="Collapsed" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,0" Background="{StaticResource SurfaceMutedBrush}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" FontWeight="SemiBold" Margin="10" Text="Schemas" />
                    <TreeView x:Name="SchemaTree"
                        SelectedItemChanged="SchemaTree_SelectedItemChanged"
                        BorderThickness="0,1,0,1" />
                </DockPanel>
            </Border>

            <TabControl x:Name="WorkspaceTabs" Grid.Column="1">
                <TabItem x:Name="ContentTab" Header="Content" Visibility="Collapsed">
                    <Grid>
                        <DataGrid x:Name="TableDataGrid"
                            AutoGenerateColumns="True"
                            CanUserAddRows="False"
                            CanUserDeleteRows="False"
                            EnableRowVirtualization="True"
                            EnableColumnVirtualization="True"
                            SelectionUnit="CellOrRowHeader"
                            GridLinesVisibility="All"
                            AutoGeneratingColumn="TableDataGrid_AutoGeneratingColumn"
                            Sorting="TableDataGrid_Sorting"
                            PreparingCellForEdit="TableDataGrid_PreparingCellForEdit"
                            CellEditEnding="TableDataGrid_CellEditEnding"
                            CurrentCellChanged="TableDataGrid_CurrentCellChanged" />
                        <Border x:Name="ContentEmptyState"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Padding="18,14"
                            IsHitTestVisible="False"
                            Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="This table is empty."
                                    FontWeight="SemiBold"
                                    HorizontalAlignment="Center" />
                                <TextBlock Text="No rows were returned for the selected table."
                                    Foreground="{StaticResource MutedTextBrush}"
                                    Margin="0,4,0,0"
                                    HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem x:Name="IndexesTab" Header="Indexes" Visibility="Collapsed">
                    <DockPanel Margin="0">
                        <Border DockPanel.Dock="Top" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="0,0,0,10" Margin="10,10,10,10">
                            <WrapPanel>
                                <TextBlock VerticalAlignment="Center" Text="Name" Margin="0,0,6,0" />
                                <TextBox x:Name="IndexNameTextBox" Width="160" Margin="0,0,12,0" />
                                <TextBlock VerticalAlignment="Center" Text="Columns"
                                    Margin="0,0,6,0" />
                                <TextBox x:Name="IndexColumnsTextBox" Width="260" Margin="0,0,12,0"
                                    ToolTip="Comma-separated column names" />
                                <CheckBox x:Name="UniqueIndexCheckBox" Content="Unique"
                                    VerticalAlignment="Center" Margin="0,0,12,0" />
                                <Button Content="Create" Padding="10,4" Margin="0,0,8,0"
                                    Click="CreateIndex_Click" />
                                <Button Content="Drop Selected" Padding="10,4"
                                    Click="DropIndex_Click" />
                            </WrapPanel>
                        </Border>
                        <DataGrid x:Name="IndexesGrid"
                            AutoGenerateColumns="False"
                            IsReadOnly="True"
                            SelectionMode="Single"
                            EnableRowVirtualization="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Index" Binding="{Binding IndexName}"
                                    Width="180" />
                                <DataGridCheckBoxColumn Header="Unique" Binding="{Binding IsUnique}"
                                    Width="80" />
                                <DataGridTextColumn Header="Seq" Binding="{Binding Sequence}"
                                    Width="60" />
                                <DataGridTextColumn Header="Column" Binding="{Binding ColumnName}"
                                    Width="180" />
                                <DataGridTextColumn Header="Type" Binding="{Binding IndexType}"
                                    Width="120" />
                                <DataGridTextColumn Header="Cardinality"
                                    Binding="{Binding Cardinality}" Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>

                <TabItem x:Name="OverviewTab" Header="Overview" Visibility="Collapsed">
                    <DataGrid x:Name="OverviewColumnsGrid"
                        AutoGenerateColumns="False"
                        IsReadOnly="True"
                        EnableRowVirtualization="True"
                        EnableColumnVirtualization="True"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Position}" Width="60" />
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="180" />
                            <DataGridTextColumn Header="Column Type" Binding="{Binding ColumnType}"
                                Width="180" />
                            <DataGridTextColumn Header="Data Type" Binding="{Binding DataType}"
                                Width="130" />
                            <DataGridTextColumn Header="Nullable" Binding="{Binding IsNullable}"
                                Width="90" />
                            <DataGridTextColumn Header="Default" Binding="{Binding DefaultValue}"
                                Width="160" />
                            <DataGridTextColumn Header="Char Length"
                                Binding="{Binding CharacterMaximumLength}" Width="110" />
                            <DataGridTextColumn Header="Precision"
                                Binding="{Binding NumericPrecision}" Width="100" />
                            <DataGridTextColumn Header="Scale" Binding="{Binding NumericScale}"
                                Width="80" />
                            <DataGridTextColumn Header="DateTime Precision"
                                Binding="{Binding DateTimePrecision}" Width="140" />
                            <DataGridTextColumn Header="Charset" Binding="{Binding CharacterSet}"
                                Width="130" />
                            <DataGridTextColumn Header="Collation" Binding="{Binding Collation}"
                                Width="180" />
                            <DataGridTextColumn Header="Key" Binding="{Binding Key}" Width="80" />
                            <DataGridTextColumn Header="Extra" Binding="{Binding Extra}" Width="180" />
                            <DataGridTextColumn Header="Comment" Binding="{Binding Comment}"
                                Width="220" />
                            <DataGridTextColumn Header="Generation Expression"
                                Binding="{Binding GenerationExpression}" Width="240" />
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem x:Name="QueryTab" Header="Query" IsSelected="True">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="150" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <avalonEdit:TextEditor x:Name="QueryEditor"
                            Background="{StaticResource InputBackgroundBrush}"
                            Foreground="{StaticResource TextBrush}"
                            FontFamily="Consolas"
                            FontSize="13"
                            ShowLineNumbers="True"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto" />
                        <Canvas x:Name="QueryCompletionLayer"
                            Grid.Row="0"
                            Panel.ZIndex="10"
                            ClipToBounds="False"
                            IsHitTestVisible="False"
                            Focusable="False">
                            <Border x:Name="QueryCompletionOverlay"
                                Width="360"
                                MaxHeight="280"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource AccentBrush}"
                                BorderThickness="1"
                                Visibility="Collapsed"
                                Focusable="False"
                                KeyboardNavigation.TabNavigation="None">
                                <Border.Resources>
                                    <SolidColorBrush
                                        x:Key="{x:Static SystemColors.HighlightBrushKey}"
                                        Color="{StaticResource AccentColor}" />
                                    <SolidColorBrush
                                        x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
                                        Color="{StaticResource AccentColor}" />
                                    <SolidColorBrush
                                        x:Key="{x:Static SystemColors.HighlightTextBrushKey}"
                                        Color="{StaticResource LightColor}" />
                                    <SolidColorBrush
                                        x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"
                                        Color="{StaticResource LightColor}" />
                                </Border.Resources>
                                <completion:CompletionList x:Name="QueryCompletionList"
                                    Focusable="False"
                                    KeyboardNavigation.TabNavigation="None" />
                            </Border>
                        </Canvas>
                        <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,1" Padding="0,8"
                            Margin="0,8">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="RunQueryButton" Content="Run selected"
                                    Padding="12,4"
                                    Click="RunQuery_Click" />
                                <Button x:Name="RunAllQueriesButton" Content="Run all"
                                    Padding="12,4"
                                    Margin="4,0,0,0" Click="RunAllQueries_Click" />
                                <Button x:Name="StopQueryButton" Content="Stop" Padding="12,4"
                                    Margin="8,0,0,0" IsEnabled="False" Click="StopQuery_Click" />
                                <TextBlock x:Name="QueryStatusText" VerticalAlignment="Center"
                                    Margin="12,0,0,0" Foreground="{StaticResource MutedTextBrush}" />
                            </StackPanel>
                        </Border>
                        <DataGrid x:Name="QueryResultGrid"
                            Grid.Row="2"
                            AutoGenerateColumns="False"
                            IsReadOnly="True"
                            EnableRowVirtualization="True"
                            EnableColumnVirtualization="True"
                            Margin="-10,0,-10,-10"
                            Visibility="Collapsed" />
                    </Grid>
                </TabItem>

                <TabItem Header="Log">
                    <DataGrid x:Name="QueryLogGrid"
                        AutoGenerateColumns="False"
                        IsReadOnly="True"
                        EnableRowVirtualization="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Binding="{Binding StartedAt}"
                                Width="180" />
                            <DataGridCheckBoxColumn Header="OK" Binding="{Binding Success}"
                                Width="50" />
                            <DataGridTextColumn Header="Duration ms" Binding="{Binding DurationMs}"
                                Width="100" />
                            <DataGridTextColumn Header="Rows" Binding="{Binding RowsAffected}"
                                Width="80" />
                            <DataGridTextColumn Header="Statement" Binding="{Binding Statement}"
                                Width="*" />
                            <DataGridTextColumn Header="Parameters" Binding="{Binding Parameters}"
                                Width="260" />
                            <DataGridTextColumn Header="Error" Binding="{Binding Error}" Width="260" />
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
            </TabControl>
        </Grid>

        <GroupBox Grid.Row="2" Header="Pending Edits" Margin="0"
            Style="{StaticResource PendingEditsGroupBoxStyle}">
            <DataGrid x:Name="PendingEditsGrid"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                EnableRowVirtualization="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Schema" Binding="{Binding SchemaName}" Width="140" />
                    <DataGridTextColumn Header="Table" Binding="{Binding TableName}" Width="200" />
                    <DataGridTextColumn Header="Column" Binding="{Binding ColumnName}" Width="140" />
                    <DataGridTextColumn Header="Old" Binding="{Binding OldValueText}" Width="220" />
                    <DataGridTextColumn Header="New" Binding="{Binding NewValueText}" Width="220" />
                    <DataGridTextColumn Header="Key" Binding="{Binding KeyDisplay}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <Border HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Margin="292,0,0,174"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Padding="8,4">
            <Border.Background>
                <StaticResource ResourceKey="SurfaceBrush" />
            </Border.Background>
            <TextBlock x:Name="SessionStatusText" Foreground="{StaticResource MutedTextBrush}" />
        </Border>
    </Grid>
</UserControl>