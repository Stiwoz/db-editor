<Window x:Class="Probe.DbEditor.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Probe.DbEditor.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:favorites="clr-namespace:Probe.DbEditor.Views.Favorites"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    behaviors:MiddleClickScrollBehavior.IsEnabled="True"
    Title="Probe DB Editor"
    Icon="Assets/app-icon.ico"
    Width="1280"
    Height="820"
    MinWidth="1040"
    MinHeight="700"
    Loaded="Window_Loaded">
    <Window.Resources>
        <Style TargetType="TextBox" BasedOn="{StaticResource BaseTextBoxStyle}">
            <Setter Property="Margin" Value="0,3,0,9" />
            <Setter Property="MinWidth" Value="220" />
        </Style>
        <Style TargetType="PasswordBox" BasedOn="{StaticResource BasePasswordBoxStyle}">
            <Setter Property="Margin" Value="0,3,0,9" />
            <Setter Property="MinWidth" Value="220" />
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource BaseComboBoxStyle}">
            <Setter Property="Margin" Value="0,3,0,9" />
            <Setter Property="MinWidth" Value="220" />
        </Style>
        <Style TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <TabControl x:Name="ConnectionsTab">
            <TabItem x:Name="ConnectionTab" Header="Connections" BorderThickness="1,1,1,0">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <DockPanel Grid.Column="0">
                        <TextBlock DockPanel.Dock="Top" FontWeight="SemiBold" Margin="0,0,0,8"
                            Text="Saved Connections" />
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                            Margin="0,12,0,0">
                            <Button Content="New" Click="NewProfile_Click" />
                            <Button Content="Folder" Click="NewFolder_Click" />
                            <Button Content="Delete" Click="DeleteProfile_Click" />
                        </StackPanel>
                        <TreeView x:Name="SavedProfilesTree"
                            AllowDrop="True"
                            PreviewMouseLeftButtonDown="SavedProfilesTree_PreviewMouseLeftButtonDown"
                            PreviewMouseMove="SavedProfilesTree_PreviewMouseMove"
                            PreviewMouseRightButtonDown="SavedProfilesTree_PreviewMouseRightButtonDown"
                            DragOver="SavedProfilesTree_DragOver"
                            Drop="SavedProfilesTree_Drop"
                            MouseDoubleClick="SavedProfilesTree_MouseDoubleClick"
                            SelectedItemChanged="SavedProfilesTree_SelectedItemChanged"
                            ContextMenuOpening="SavedProfilesTree_ContextMenuOpening">
                            <TreeView.ContextMenu>
                                <ContextMenu x:Name="SavedProfilesContextMenu">
                                    <MenuItem x:Name="FavoriteContextColorMenu" Header="Color">
                                        <MenuItem Header="No Color" Tag="0"
                                            Click="FavoriteContextColor_Click">
                                            <MenuItem.Icon>
                                                <Border Width="12"
                                                    Height="12"
                                                    CornerRadius="6"
                                                    Background="Transparent"
                                                    BorderBrush="#7F7F7F"
                                                    BorderThickness="1.5" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Gray" Tag="1"
                                            Click="FavoriteContextColor_Click">
                                            <MenuItem.Icon>
                                                <Border Width="12" Height="12" CornerRadius="6"
                                                    Background="#7F7F7F" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Green" Tag="2"
                                            Click="FavoriteContextColor_Click">
                                            <MenuItem.Icon>
                                                <Border Width="12" Height="12" CornerRadius="6"
                                                    Background="#34C759" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Purple" Tag="3"
                                            Click="FavoriteContextColor_Click">
                                            <MenuItem.Icon>
                                                <Border Width="12" Height="12" CornerRadius="6"
                                                    Background="#AF52DE" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Blue" Tag="4"
                                            Click="FavoriteContextColor_Click">
                                            <MenuItem.Icon>
                                                <Border Width="12" Height="12" CornerRadius="6"
                                                    Background="#007AFF" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Yellow" Tag="5"
                                            Click="FavoriteContextColor_Click">
                                            <MenuItem.Icon>
                                                <Border Width="12" Height="12" CornerRadius="6"
                                                    Background="#FFCC00" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Red" Tag="6"
                                            Click="FavoriteContextColor_Click">
                                            <MenuItem.Icon>
                                                <Border Width="12" Height="12" CornerRadius="6"
                                                    Background="#FF3B30" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Orange" Tag="7"
                                            Click="FavoriteContextColor_Click">
                                            <MenuItem.Icon>
                                                <Border Width="12" Height="12" CornerRadius="6"
                                                    Background="#FF9500" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Header="New Connection"
                                        Click="FavoriteContextNewConnection_Click" />
                                    <MenuItem Header="New Folder"
                                        Click="FavoriteContextNewFolder_Click" />
                                    <MenuItem x:Name="FavoriteContextRenameMenuItem"
                                        Header="Rename"
                                        Click="FavoriteContextRename_Click" />
                                    <MenuItem x:Name="FavoriteContextDeleteProfileMenuItem"
                                        Header="Delete Favorite"
                                        Click="FavoriteContextDeleteProfile_Click" />
                                    <MenuItem x:Name="FavoriteContextDeleteFolderMenuItem"
                                        Header="Delete Folder"
                                        Click="FavoriteContextDeleteFolder_Click" />
                                </ContextMenu>
                            </TreeView.ContextMenu>
                            <TreeView.Resources>
                                <HierarchicalDataTemplate DataType="{x:Type favorites:FavoriteTreeItemViewModel}"
                                    ItemsSource="{Binding Children}">
                                    <Border Background="{Binding BackgroundBrush}"
                                        CornerRadius="4"
                                        Padding="6,3"
                                        Margin="0,1"
                                        HorizontalAlignment="Stretch">
                                        <Grid>
                                            <TextBlock Text="{Binding Name}"
                                                VerticalAlignment="Center"
                                                TextTrimming="CharacterEllipsis">
                                                <TextBlock.Style>
                                                    <Style TargetType="{x:Type TextBlock}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEditingName}"
                                                                Value="True">
                                                                <Setter Property="Visibility"
                                                                    Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Margin="0"
                                                Padding="4,1"
                                                MinWidth="0"
                                                IsVisibleChanged="FavoriteRenameTextBox_IsVisibleChanged"
                                                KeyDown="FavoriteRenameTextBox_KeyDown"
                                                LostFocus="FavoriteRenameTextBox_LostFocus">
                                                <TextBox.Style>
                                                    <Style TargetType="{x:Type TextBox}"
                                                        BasedOn="{StaticResource BaseTextBoxStyle}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEditingName}"
                                                                Value="True">
                                                                <Setter Property="Visibility"
                                                                    Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </Grid>
                                    </Border>
                                </HierarchicalDataTemplate>
                            </TreeView.Resources>
                        </TreeView>
                    </DockPanel>

                    <Border Grid.Column="2" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" Background="{StaticResource SurfaceBrush}" Padding="16">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                            <StackPanel MaxWidth="720" HorizontalAlignment="Left">

                                <TextBlock Text="Profile name" />
                                <TextBox x:Name="ProfileNameTextBox" />
                                <TextBlock Text="Color" />
                                <ListBox x:Name="ProfileColorList"
                                    BorderThickness="0"
                                    Background="Transparent"
                                    SelectionChanged="ProfileColorList_SelectionChanged"
                                    Margin="0,3,0,9"
                                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                    ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="{x:Type ListBoxItem}">
                                            <Setter Property="Padding" Value="3" />
                                            <Setter Property="Margin" Value="0,0,6,0" />
                                            <Setter Property="Width" Value="26" />
                                            <Setter Property="Height" Value="26" />
                                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                                            <Setter Property="VerticalContentAlignment" Value="Center" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="16"
                                                Height="16"
                                                CornerRadius="8"
                                                Background="{Binding SwatchBrush}"
                                                BorderBrush="{Binding BorderBrush}"
                                                BorderThickness="1.5"
                                                ToolTip="{Binding Label}" />
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <TextBlock Text="Mode" />
                                <ComboBox x:Name="ProtocolCombo"
                                    SelectionChanged="ProtocolCombo_SelectionChanged" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="160" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" x:Name="TcpHostPanel">
                                        <TextBlock Text="Host / domain / IP" />
                                        <TextBox x:Name="HostTextBox" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" x:Name="TcpPortPanel">
                                        <TextBlock Text="Port" />
                                        <TextBox x:Name="PortTextBox" />
                                    </StackPanel>
                                </Grid>

                                <StackPanel x:Name="PipePanel" Visibility="Collapsed">
                                    <TextBlock Text="Windows pipe name" />
                                    <TextBox x:Name="PipeNameTextBox" />
                                </StackPanel>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Database user" />
                                        <TextBox x:Name="UserNameTextBox" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Database password" />
                                        <PasswordBox x:Name="PasswordBox" />
                                        <CheckBox x:Name="SavePasswordCheckBox"
                                            Content="Save password"
                                            ToolTip="Protects the saved password with Windows DPAPI for the current Windows user."
                                            Margin="0,-4,0,9" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Default schema (optional)" />
                                <TextBox x:Name="DefaultSchemaTextBox" />

                                <TextBlock Text="Database TLS mode" />
                                <ComboBox x:Name="TlsModeCombo" />

                                <GroupBox x:Name="SshPanel" Header="SSH Tunnel"
                                    Visibility="Collapsed" Margin="0,8,0,12" Padding="12">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="160" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="SSH host" />
                                                <TextBox x:Name="SshHostTextBox" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="SSH port" />
                                                <TextBox x:Name="SshPortTextBox" />
                                            </StackPanel>
                                        </Grid>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="SSH user" />
                                                <TextBox x:Name="SshUserNameTextBox" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="SSH password" />
                                                <PasswordBox x:Name="SshPasswordBox" />
                                                <CheckBox x:Name="SaveSshPasswordCheckBox"
                                                    Content="Save SSH password"
                                                    ToolTip="Protects the saved SSH password with Windows DPAPI for the current Windows user."
                                                    Margin="0,-4,0,9" />
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock Text="Private key path" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="SshKeyPathTextBox" />
                                            <Button x:Name="BrowseSshKeyButton"
                                                Grid.Column="2"
                                                Content="..."
                                                MinWidth="44"
                                                Margin="0,3,0,9"
                                                Padding="10,5"
                                                ToolTip="Browse for an SSH private key file."
                                                Click="BrowseSshKey_Click" />
                                        </Grid>

                                        <TextBlock Text="Private key passphrase" />
                                        <PasswordBox x:Name="SshKeyPassphraseBox" />
                                    </StackPanel>
                                </GroupBox>

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button x:Name="TestConnectionButton"
                                        Content="Test Connection"
                                        Click="TestConnection_Click" />
                                    <Button x:Name="ConnectButton"
                                        Content="Connect"
                                        Click="Connect_Click" />
                                    <Button Content="Save Profile" Click="SaveProfile_Click" />
                                </StackPanel>

                                <TextBlock x:Name="ConnectionStatusText"
                                    Margin="0,12,0,0"
                                    TextWrapping="Wrap"
                                    Foreground="{StaticResource MutedTextBrush}" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
